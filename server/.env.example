# HuggingFace API Token (optional, only needed for gated models like Llama, Gemma)
# Get your token from https://huggingface.co/settings/tokens
# Then accept the license on the model's page
HF_TOKEN=xxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Inference Mode: "download" or "cache"
# - download: Use locally loaded models (requires loading first, no API calls)
# - cache: Proxy to HuggingFace Inference API (no model loading needed, uses API quota)
INFERENCE_MODE=download