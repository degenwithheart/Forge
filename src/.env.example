# HuggingFace Token (optional for higher limits and gated model access)
# Get from: https://huggingface.co/settings/tokens
VITE_HUGGINGFACE_TOKEN=xxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# OpenAI API Key (optional, requires PAID account)
# Get from: https://platform.openai.com/api-keys
# Note: OpenAI is disabled by default - enable in Providers tab if you have a paid account
VITE_OPENAI_API_KEY=xxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
